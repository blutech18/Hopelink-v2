{
  "name": "hopelink",
  "version": "1.0.0",
  "description": "Community-driven donation management platform connecting donors, recipients, and volunteers",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-warnings concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cross-env NODE_OPTIONS=--no-warnings vite",
    "dev:server": "cross-env NODE_OPTIONS=--no-warnings nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cross-env NODE_OPTIONS=--no-warnings node server/index.js",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "setup": "node scripts/setup.js",
    "clear-db": "node scripts/clear_database.js",
    "seed:data": "node scripts/seed_sample_data.js",
    "test": "echo \"No tests specified yet\" && exit 0",
    "check": "npm run lint && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-google-maps/api": "^2.20.7",
    "@supabase/supabase-js": "^2.38.0",
    "@tanstack/react-query": "^5.90.21",
    "@vis.gl/react-google-maps": "^1.5.5",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "framer-motion": "^10.12.4",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.263.1",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.59.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.3.0",
    "tailwind-merge": "^1.14.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "nodemon": "^3.1.11",
    "pg": "^8.16.3",
    "postcss": "^8.4.23",
    "tailwindcss": "^3.3.0",
    "vite": "^7.2.4"
  },
  "keywords": [
    "donation",
    "community",
    "volunteer",
    "charity",
    "react",
    "supabase"
  ],
  "author": "HopeLink Team",
  "license": "MIT"
}
